# =====================================================
# ШАБЛОН — скопировать в .env и заполнить реальными значениями
# .env НЕ коммитится в git (он в .gitignore)
# =====================================================

# Подключение к PostgreSQL (Timeweb Cloud)
DATABASE_URL=postgresql://gen_user:ВАSH_НОВЫЙ_ПАРОЛЬ@45.8.96.5:5432/analizator2?sslmode=require

# JWT секрет — сгенерировать командой:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=ВСТАВЬТЕ_СГЕНЕРИРОВАННЫЙ_СЕКРЕТ

# Разрешённые CORS origins (через запятую)
# В production: добавить ваш домен, например https://wm-analytics.ru
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5000

# OpenAI (опционально, для AI-анализа)
# OPENAI_API_KEY=

# Node окружение
NODE_ENV=production
PORT=5000
